#include <iostream>
using namespace std;

int main() {
    setlocale(LC_ALL, "Rus");
    int n;
    cin >> n;
    double A[100][100];

    for (int i = 0; i < n; i++)
        for (int j = 0; j < n; j++)
            cin >> A[i][j];

    double mn = A[0][0];
    for (int i = 0; i < n; i++)
        for (int j = 0; j < n; j++)
            if (A[i][j] < mn) mn = A[i][j];

    for (int i = 0; i < n; i++) {
        double sum = 0;
        bool hasMin = false;
        for (int j = 0; j < n; j++) {
            sum += A[i][j];
            if (A[i][j] == mn) hasMin = true;
        }
        if (hasMin) cout << "Строка " << i + 1 << ": сумма = " << sum << endl;
    }

    return 0;
}
